<div id="videoCanvas" class="videoCanvas">

    <!-- Local User -->
    <div class="videoCard local"
         id="localUser"
         data-user="me">

        <div class="videoHeader">

            <div class="videoName">
                You
            </div>

            <div class="videoButtons">

                <button class="pinBtn">📌</button>
                <button class="fullscreenBtn">⛶</button>
                <button class="menuBtn">⋯</button>

            </div>

        </div>

        <div class="videoBody">

            <video
                autoplay
                muted
                playsinline
                id="localVideo">
            </video>

            <div class="resizeHandle resize-br"></div>

        </div>

    </div>


    <!-- Stranger -->

    <div class="videoCard stranger"
         id="remote1"
         data-user="remote">

        <div class="videoHeader">

            <div class="videoName">

                Stranger

                <span class="country">
                    🇺🇸
                </span>

            </div>

            <div class="videoButtons">

                <button class="pinBtn">📌</button>
                <button class="fullscreenBtn">⛶</button>
                <button class="menuBtn">⋯</button>

            </div>

        </div>

        <div class="videoBody">

            <video
                autoplay
                playsinline
                id="remoteVideo1">
            </video>

            <div class="resizeHandle resize-br"></div>

        </div>

    </div>

</div>
